# Copy to .env and fill in values from your Supabase project settings.
# Do not commit .env — add the same variables in Vercel (Project → Environment Variables).

SUPABASE_PUBLISHABLE_KEY=
SUPABASE_URL=
VITE_SUPABASE_PROJECT_ID=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_URL=

# Telegram Bot API — create a bot via @BotFather, then send /start to it from your account
TELEGRAM_BOT_TOKEN=
# Optional; defaults to 164025073 if omitted
TELEGRAM_CHAT_ID=
